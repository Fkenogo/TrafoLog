# Server
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
# Development may use localhost. Production must set an absolute, non-loopback
# HTTP/HTTPS origin with no path; a trailing slash is normalized.
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kVAssetTracker
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# JWT
# Required in every deployed environment. Production rejects this documented
# placeholder; generate a strong environment-specific value and never commit it.
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# MinIO (File Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_PHOTOS=kVAssetTracker-photos
MINIO_BUCKET_REPORTS=kVAssetTracker-reports
MINIO_BUCKET_BACKUPS=kVAssetTracker-backups

# Backups
# BACKUP_STORAGE_PROVIDER options: local|minio
BACKUP_STORAGE_PROVIDER=local
BACKUP_LOCAL_DIR=/tmp/kvassettracker-backups
BACKUP_PREFIX=backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_ENABLED=false

# Email (SMTP)
# Pilot checklist:
# 1. Set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, and SMTP_FROM for the pilot mail provider.
# 2. Start the backend and create or assign a fault to trigger an assignment notification.
# 3. Confirm the in-app notification appears even if SMTP delivery fails.
# 4. Confirm the recipient receives the email before pilot handoff.
# 5. Do not commit real SMTP credentials.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@kVAssetTracker.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Mapbox
MAPBOX_TOKEN=your_mapbox_token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760 # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf
